# There are a variety of Docker Compose files that can be used to run the API and worker.
# docker-compose.server.yml - API server, RabbitMQ, Meilisearch
# docker-compose.autoscaler.yml - Autoscaler when using vast.ai to run workers
# docker-compose.worker.yml - post_transcribe worker
# docker-compose.worker-whisper.yml - Whisper transcription worker + local ASR sidecar
# docker-compose.worker-api.yml - Vendor API transcription worker (OpenAI / DeepInfra)
# docker-compose.worker-qwen.yml - Qwen transcription worker + local ASR service
# docker-compose.worker-voxtral.yml - Voxtral transcription worker + local or remote ASR service
# docker-compose.gpu.yml - Nvidia GPU reservation overlay for GPU-backed workers
# docker-compose.minio.yml - MinIO (S3) server for local file storage

# By default, this runs a self-contained server stack, the post-processing worker, a Whisper worker, and MinIO.
# NOTE: On Windows, use ; to separate the files instead of :
COMPOSE_FILE=docker-compose.server.yml:docker-compose.worker.yml:docker-compose.worker-whisper.yml:docker-compose.gpu.yml:docker-compose.minio.yml

#
# Backend routing
#

# Used when an API request does not explicitly set transcription_backend.
DEFAULT_TRANSCRIPTION_BACKEND=whisper

# Backend-specific compose files set these automatically.
# Supported values: whisper, api, qwen, voxtral
# TRANSCRIPTION_BACKEND=whisper
# CELERY_QUEUES=transcribe_whisper

# Generic ASR API settings for workers that call a sibling or remote OpenAI-compatible transcription service.
# Whisper defaults to speaches on http://asr-whisper:8000/v1.
# ASR_API_URL=http://asr-whisper:8000/v1
# ASR_PROVIDER=speaches
# ASR_MODEL=Systran/faster-distil-whisper-small.en
# ASR_WHISPER_IMAGE=ghcr.io/speaches-ai/speaches:latest-cuda
# Qwen server images are published at ghcr.io/trunk-reporter/qwen3-asr-server:{gpu|cpu}
# ASR_QWEN_IMAGE=ghcr.io/trunk-reporter/qwen3-asr-server:gpu
# Voxtral via vLLM defaults to mistralai/Voxtral-Mini-4B-Realtime-2602.
# ASR_VOXTRAL_IMAGE=vllm/vllm-openai:latest
# HF_TOKEN=hf_xxx

#
# Whisper provider overrides
#

# Used by the `api` backend and for auto-routing vendor-hosted transcription off the GPU queue.
# Valid values: whisper-asr-api, openai, deepinfra
WHISPER_IMPLEMENTATION=whisper-asr-api

# Whisper model override.
# For the default sidecar this should match speaches' transcription model ID.
WHISPER_MODEL=Systran/faster-distil-whisper-small.en

# Desired CUDA version to use (as well as some special options).
# Used by GPU-backed worker and ASR images.
# Note: if you have a newer CUDA version installed on your system, still use 12.1.0 here
CUDA_VERSION=12.1.0

# OpenAI API key, if using the `api` backend with WHISPER_IMPLEMENTATION=openai
# OPENAI_API_KEY=

# DeepInfra API key, if using the `api` backend with WHISPER_IMPLEMENTATION=deepinfra
# DEEPINFRA_API_KEY=
# Optional override for DeepInfra base URL
# DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai

#
# Queue settings
#

# CELERY_LOGLEVEL=debug
CELERY_BROKER_URL=amqp://rabbitmq:5672
CELERY_RESULT_BACKEND=rpc://rabbitmq:5672
# CELERY_CONCURRENCY=1
# This multiplier should be 0 if using batching
# CELERY_PREFETCH_MULTIPLIER=1

FLOWER_BROKER_API=http://rabbitmq:15672/api/

# Vast autoscaling
# AUTOSCALE_BACKEND=whisper
# AUTOSCALE_QUEUE=transcribe_whisper
# AUTOSCALE_WORKER_IMAGE=ghcr.io/crimeisdown/trunk-transcribe:main-whisper-large-v3-cuda_12.1.0
# AUTOSCALE_MIN_INSTANCES=1
# AUTOSCALE_MAX_INSTANCES=10
# AUTOSCALE_INTERVAL=60
# Optional when the autoscaler cannot infer the right GPU RAM requirement from WHISPER_MODEL.
# AUTOSCALE_GPU_RAM_MB=24576
# Note: the `api` backend does not need a GPU. Run docker-compose.worker-api.yml on standard compute instead.

# To set auth on RabbitMQ (update URLs above if so, in the form user:pass@rabbitmq)
# RABBITMQ_DEFAULT_USER=
# RABBITMQ_DEFAULT_PASS=

#
# Database settings
#

POSTGRES_HOST=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=trunk_transcribe

#
# API settings
#

# This should be a publicly-accessible URL to the API server, from whever the worker is being run
API_BASE_URL=http://api:8000/api/v1
API_KEY=testing
# Comma-separated list of allowed browser origins for API CORS
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# Host port exposed for the standalone chat UI container
CHAT_UI_PORT=7932
# Internal AG-UI endpoint used by the frontend CopilotKit runtime
CHAT_AGENT_URL=http://chat-ui:7932
# Chat UI model in provider:model format. If no provider is included, OpenAI is assumed.
# CHAT_UI_MODEL=openai:gpt-4o-mini
# Optional custom system prompt for chat agent behavior
# CHAT_UI_SYSTEM_PROMPT=
# Maximum matching calls the AI agent will inspect per analysis request
# CHAT_UI_MAX_ANALYSIS_HITS=200

# Backward-compatible model fallback used by scanner chat components.
# If set, CHAT_UI_MODEL takes precedence for the web UI container.
# CHAT_SUMMARY_MODEL=openai:gpt-4o-mini
# Maximum allowed time range for legacy summary request validation
# CHAT_SUMMARY_MAX_WINDOW_HOURS=24
# Maximum records to request per MCP search query
# CHAT_SUMMARY_MAX_HITS=250
# Timeout in seconds for Meilisearch MCP tool calls
# CHAT_SUMMARY_MCP_TIMEOUT_SECONDS=20

#
# Search settings
#

# Version of Meilisearch to use (e.g. v1.4.0)
# MEILI_VERSION=

# MEILI_MASTER_KEY=testing
# MEILI_URL=http://meilisearch:7700
# To use a different index name other than calls:
# MEILI_INDEX=calls
# For large systems, to make a new index for each month (e.g. calls_2024_01); MEILI_INDEX becomes the prefix
# MEILI_INDEX_SPLIT_BY_MONTH=true

# Version of Typesense to use
TYPESENSE_VERSION=27.1

TYPESENSE_API_KEY=testing
TYPESENSE_URL=http://typesense:8108

SEARCH_UI_URL=http://localhost:3000

#
# Storage settings
#

# These settings are for an S3 bucket that will contain call audio, so it can be played back later as part of search.

# S3_BUCKET=my-bucket
# S3_PUBLIC_URL=https://my-bucket.s3.us-east-1.amazonaws.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# If using a different location than us-east-1 or a provider with an S3-compatible API
# S3_ENDPOINT=

# To use MinIO and save files locally instead of signing up for S3, uncomment this section instead
S3_BUCKET=trunk-transcribe
# The S3 public URL should be the publicly-accessible IP or domain of the MinIO server, with the port and bucket name
S3_PUBLIC_URL=http://127.0.0.1:9000/trunk-transcribe
AWS_ACCESS_KEY_ID=changeme
AWS_SECRET_ACCESS_KEY=changeme
S3_ENDPOINT=http://minio:9000

#
# Notification settings
#

# These values are in seconds
# DELAYED_CALL_THRESHOLD=120
# MAX_CALL_AGE=1200

#
# Third party service settings
#

# TELEGRAM_BOT_TOKEN=

# OPENAI_API_KEY=

# GOOGLE_GEMINI_API_KEY=

# GOOGLE_MAPS_API_KEY=
# MAPBOX_API_KEY=
# GEOCODIO_API_KEY=
# GEOAPIFY_API_KEY=
# ARCGIS_USERNAME=
# ARCGIS_PASSWORD=

# GEOCODING_SERVICE=
# GEOCODING_BOUNDS="41.6,-87.9|42,-87.5"
# GEOCODING_CITY=Chicago
# GEOCODING_STATE=IL
# GEOCODING_COUNTRY=US
# GEOCODING_ENABLED_SYSTEMS="system1,system2"

# SENTRY_DSN=

# BCFY_USER=
# BCFY_PASS=
